# Required: PostgreSQL connection string (pooled, port 6543)
DATABASE_URL=<POOLED_POSTGRES_URL>

# Required: Direct PostgreSQL connection (port 5432, used for migrations)
DIRECT_URL=<DIRECT_POSTGRES_URL>

# Required: 32+ character secret for session signing and URL encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=<YOUR_32_CHARACTER_SECRET_KEY>

# Required: Bcrypt hash of admin password
# Generate with: npx bcrypt-cli hash <your-password>
ADMIN_PASSWORD_HASH=<BCRYPT_HASH>
